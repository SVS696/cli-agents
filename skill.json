{
  "name": "cli-agents",
  "version": "2.1.0",
  "description": "CLI AI Agents: Gemini (Auto/3-pro/2.5-pro/flash, 1M ctx), Claude (sonnet-4.6/opus-4.7/haiku-4.5, 200k ctx), Codex (gpt-5.4, 400k ctx, deep reasoning frontier — not code-only). Includes Ollama-compatible server for n8n.",
  "type": "cli",
  "command": "python",
  "args": [
    "cli_caller.py"
  ],
  "tools": [
    {
      "name": "call_gemini",
      "description": "Call Gemini (Auto: gemini-3-pro-preview → gemini-2.5-pro). 1M context.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Prompt to send"
          },
          "systemprompt": {
            "type": "string",
            "enum": [
              "default",
              "planner",
              "codereviewer"
            ]
          },
          "cwd": {
            "type": "string",
            "description": "Working directory for file access"
          },
          "timeout": {
            "type": "integer",
            "default": 120
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "gemini",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_gemini_3_pro",
      "description": "Call Gemini 3 Pro Preview explicitly. 1M context.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 120
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "gemini-3-pro",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_gemini_flash",
      "description": "Call Gemini 2.5 Flash (fast). 1M context.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 60
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "gemini-2.5-flash",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_claude",
      "description": "Call Claude (default model). 200k context.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          },
          "systemprompt": {
            "type": "string",
            "enum": [
              "default",
              "planner",
              "codereviewer"
            ]
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 120
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "claude",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_claude_sonnet",
      "description": "Call Claude Sonnet 4. 200k context.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 120
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "claude-sonnet",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_claude_opus",
      "description": "Call Claude Opus 4 (most capable). 200k context.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 180
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "claude-opus",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_codex",
      "description": "Call OpenAI Codex (default gpt-5.4). General-purpose reasoning frontier model — architecture, planning, research, analysis, code. 400k context.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          },
          "systemprompt": {
            "type": "string",
            "enum": [
              "default",
              "planner",
              "codereviewer",
              "codex_codereviewer"
            ]
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 300
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "codex",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_codex_review",
      "description": "Run native `codex review` with custom review instructions (prompt). 400k context.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Custom review instructions"
          },
          "cwd": {
            "type": "string",
            "description": "Repo directory to review"
          },
          "timeout": {
            "type": "integer",
            "default": 300
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "codex-review",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_codex_review_uncommitted",
      "description": "Run `codex review --uncommitted` on staged/unstaged/untracked changes in cwd.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Optional extra instructions (can be empty)"
          },
          "cwd": {
            "type": "string",
            "description": "Repo directory"
          },
          "timeout": {
            "type": "integer",
            "default": 300
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "codex-review-uncommitted",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_codex_json",
      "description": "Call codex exec --json for structured JSONL event stream. Same underlying model (gpt-5.4) — not code-only.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 300
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "codex-json",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "call_gemini_json",
      "description": "Call Gemini with `-o json` for structured JSON output.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string"
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 120
          }
        },
        "required": [
          "prompt"
        ]
      },
      "args": [
        "--model",
        "gemini-json",
        "--prompt",
        "{prompt}"
      ]
    },
    {
      "name": "council_panel",
      "description": "Parallel multi-agent panel: every agent answers the topic independently, synthesizer produces consensus/divergence/recommendation. Fast, cheap, good for option discovery.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "description": "Question for the council"
          },
          "agents": {
            "type": "string",
            "description": "Comma-separated model names"
          },
          "synthesize_with": {
            "type": "string",
            "default": "claude-opus"
          },
          "output": {
            "type": "string",
            "default": "discussion.md"
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 300
          }
        },
        "required": [
          "topic",
          "agents"
        ]
      },
      "script": "agent_council.py",
      "args": [
        "--mode",
        "panel",
        "--agents",
        "{agents}",
        "--topic",
        "{topic}",
        "--synthesize-with",
        "{synthesize_with}",
        "--output",
        "{output}"
      ]
    },
    {
      "name": "council_debate",
      "description": "Sequential debate A→B→C with shared markdown. Each agent keeps its own session chain. Stops on CONCLUDED / no-progress / rounds cap.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string"
          },
          "agents": {
            "type": "string",
            "description": "Comma-separated model names"
          },
          "rounds": {
            "type": "integer",
            "default": 5
          },
          "output": {
            "type": "string",
            "default": "discussion.md"
          },
          "cwd": {
            "type": "string"
          },
          "timeout": {
            "type": "integer",
            "default": 300
          }
        },
        "required": [
          "topic",
          "agents"
        ]
      },
      "script": "agent_council.py",
      "args": [
        "--mode",
        "debate",
        "--agents",
        "{agents}",
        "--topic",
        "{topic}",
        "--rounds",
        "{rounds}",
        "--output",
        "{output}"
      ]
    }
  ],
  "server": {
    "type": "ollama-compat",
    "script": "ollama_compat_server.py",
    "port": 11434,
    "launchd": "com.svs.ollama-compat",
    "models": [
      "gemini",
      "gemini-3-pro",
      "gemini-2.5-pro",
      "gemini-2.5-flash",
      "claude",
      "claude-sonnet",
      "claude-opus",
      "claude-haiku",
      "codex"
    ]
  },
  "metadata": {
    "author": "svs",
    "tags": [
      "cli-agents",
      "ai-models",
      "gemini",
      "claude",
      "codex",
      "n8n",
      "ollama"
    ],
    "models": {
      "gemini": "Auto (3-pro-preview → 2.5-pro), 1M tokens",
      "gemini-3-pro": "Gemini 3 Pro Preview, 1M tokens",
      "gemini-2.5-pro": "Gemini 2.5 Pro, 1M tokens",
      "gemini-2.5-flash": "Gemini 2.5 Flash (fast), 1M tokens",
      "gemini-2.5-flash-lite": "Gemini 2.5 Flash Lite, 1M tokens",
      "claude": "Claude default, 200k tokens",
      "claude-sonnet": "Claude Sonnet 4.6, 200k tokens",
      "claude-opus": "Claude Opus 4.7, 200k tokens (1M beta tier)",
      "claude-haiku": "Claude Haiku 4.5, 200k tokens",
      "codex": "OpenAI Codex (gpt-5.4 default), 400k tokens",
      "codex-gpt-5-codex": "gpt-5-codex via Codex CLI, 400k tokens",
      "codex-gpt-5.1-codex": "gpt-5.1-codex via Codex CLI, 400k tokens"
    }
  }
}